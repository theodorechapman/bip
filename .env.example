# ─── Core Platform ───────────────────────────────────
# CONVEX_DEPLOYMENT=<your-convex-deployment>
# PAYMENTS_MODE=free|metered
# SUBSIDY_MODE=true|false
# MIN_INTENT_BUDGET_USD=1
# INVITE_CODES=<comma-separated invite codes>

# ─── Solana Funding ─────────────────────────────────
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_FUNDING_USD_PER_SOL=100

# ─── Browser Use ─────────────────────────────────────
# BROWSER_USE_API_KEY=<browser-use cloud api key>
# BROWSER_USE_MAX_STEPS=30

# ─── Anthropic (LLM for product copy, etc) ──────────
# ANTHROPIC_API_KEY=<your anthropic api key>

# ─── Bitrefill ───────────────────────────────────────
# BITREFILL_API_KEY=<bitrefill api key>
# BITREFILL_API_SECRET=<bitrefill api secret>

# ─── AgentMail ───────────────────────────────────────
# AGENTMAIL_API_KEY=<agentmail api key>

# ─── Shopify Admin API ──────────────────────────────
# SHOPIFY_SHOP_DOMAIN=<your-store>.myshopify.com
# SHOPIFY_ACCESS_TOKEN=<shopify admin api access token>
# SHOPIFY_WEBHOOK_SECRET=<shopify webhook hmac secret>

# ─── CJ Dropshipping ────────────────────────────────
# CJ_EMAIL=<cj dropshipping account email>
# CJ_PASSWORD=<cj dropshipping account password>

# ─── Provider Allowlist ─────────────────────────────
# ALLOWED_PROVIDERS=bitrefill,namecheap,openrouter,elevenlabs,cj,shopify,x

# ─── Google AI (image generation, optional) ──────────
# GOOGLE_AI_API_KEY=<google ai api key for imagen>

# ─── OpenAI (optional fallback LLM) ──────────────────
# OPENAI_API_KEY=<openai api key>

# ─── 2Captcha (Arkose/FunCaptcha solving) ──────────
# TWOCAPTCHA_API_KEY=<your 2captcha api key>
# X_ARKOSE_PUBLIC_KEY=<override X arkose public key, optional>

# ─── hCaptcha ───────────────────────────────────────
# HCAPTCHA_SECRET_KEY=<hcaptcha secret>
# HCAPTCHA_SITEKEY=<hcaptcha site key>
