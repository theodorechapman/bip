# ── Core platform ──────────────────────────────────────────────────
CONVEX_DEPLOYMENT=<your-convex-deployment>
CONVEX_SITE_URL=<your-convex-site-url>
INVITE_CODES=<comma-separated invite codes>
PAYMENTS_MODE=free
MIN_INTENT_BUDGET_USD=1
SUBSIDY_MODE=true
ALLOWED_PROVIDERS=bitrefill,namecheap,openrouter,elevenlabs,cj,shopify,x

# ── Auth (optional if AUTH_BYPASS=true) ────────────────────────────
AUTH_BYPASS=true
HCAPTCHA_SECRET_KEY=<hcaptcha secret>
HCAPTCHA_SITE_KEY=<hcaptcha site key>

# ── Browser Use execution ──────────────────────────────────────────
BROWSER_USE_API_KEY=<browser-use-cloud-api-key>
BROWSER_USE_API_BASE=https://api.browser-use.com
BROWSER_USE_MAX_STEPS=30
BROWSER_USE_PROXY_COUNTRY=us

# ── AgentMail (for verification flows) ─────────────────────────────
AGENTMAIL_API_KEY=<agentmail-api-key>
AGENTMAIL_BASE_URL=https://api.agentmail.to
AGENTMAIL_WEBHOOK_SECRET=<shared webhook secret>

# ── Solana / funding ──────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_FUNDING_USD_PER_SOL=100
SOL_AUTO_SPEND_CAP_USD=10

# ── Bitrefill ─────────────────────────────────────────────────────
BITREFILL_API_KEY=<bitrefill-api-key>
BITREFILL_API_BASE=https://api.bitrefill.com

# ── Treasury cards ────────────────────────────────────────────────
ADMIN_CARD_WRITE_TOKEN=<admin-token>
DEFAULT_TREASURY_CARD_REF=<default card ref for giftcard intents>

# ── CAPTCHA solving (for X.com signup) ────────────────────────────
TWOCAPTCHA_API_KEY=<2captcha-api-key>
X_ARKOSE_PUBLIC_KEY=<override arkose public key>

# ── Shopify (fallback if agent has no stored creds) ───────────────
SHOPIFY_SHOP_DOMAIN=<store>.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_<token>

# ── CJ Dropshipping (fallback if agent has no stored creds) ──────
CJ_EMAIL=<cj-email>
CJ_PASSWORD=<cj-password>

# ── LLM (for Shopify product copy generation) ────────────────────
ANTHROPIC_API_KEY=<anthropic-api-key>

# ── Observability ─────────────────────────────────────────────────
LAMINAR_INGEST_URL=<laminar trace ingest url>
LMNR_PROJECT_API_KEY=<laminar project api key>
HUD_TRACE_URL=<hud trace url>
HUD_API_KEY=<hud api key>

# ── API key validation endpoints ──────────────────────────────────
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1
